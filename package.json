{
  "name": "catchment-school",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "npm run build && cd dist/server && npx wrangler deploy --config wrangler.json",
    "test": "curl -s -o /dev/null -w 'homepage: %{http_code}\\nschool:   %{http_code}\\n' https://catchment-school.sunnypat81.workers.dev/ https://catchment-school.sunnypat81.workers.dev/school/ab-kettleby-primary-school-140696",
    "astro": "astro",
    "data:fetch": "node scripts/fetch-schools.mjs",
    "data:parse": "node scripts/parse-schools.mjs && node scripts/gen-geo.mjs",
    "data:all": "npm run data:fetch && npm run data:parse"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.0",
    "@astrojs/sitemap": "^3.7.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^6.0.3",
    "csv-parse": "^6.1.0",
    "tailwindcss": "^4.2.1"
  }
}
