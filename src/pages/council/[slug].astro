---
import Base from '../../layouts/Base.astro';
import schools from '../../data/schools.json';
import las from '../../data/las.json';
import SchoolCard from '../../components/SchoolCard.astro';

export async function getStaticPaths() {
  return (las as any[]).map((la: any) => ({
    params: { slug: la.slug },
    props: { la },
  }));
}

const { la } = Astro.props;
const laSchools = (schools as any[]).filter((s: any) => s.laSlug === la.slug);

const byTown: Record<string, any[]> = {};
for (const s of laSchools) {
  const key = s.town || 'Other';
  if (!byTown[key]) byTown[key] = [];
  byTown[key].push(s);
}
const towns = Object.entries(byTown).sort((a, b) => b[1].length - a[1].length);

const primaries = laSchools.filter((s: any) => s.phase === 'Primary').length;
const secondaries = laSchools.filter((s: any) => s.phase === 'Secondary').length;
const townCount = Object.keys(byTown).length;

// Intent-matched title — "[LA] school catchment areas" is the search pattern
const title = `${la.name} School Catchment Areas — Find Schools Near You | catchment.school`;
const description = `Find all ${laSchools.length} schools in ${la.name}, including ${primaries} primary and ${secondaries} secondary schools across ${townCount} areas. View catchment area guidance and admissions policies.`;

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Schools in ${la.name}`,
  "numberOfItems": laSchools.length,
  "itemListElement": laSchools.slice(0, 10).map((s: any, i: number) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": s.name,
    "url": `https://catchment.school/school/${s.slug}`
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://catchment.school/" },
    { "@type": "ListItem", "position": 2, "name": "All Councils", "item": "https://catchment.school/council" },
    { "@type": "ListItem", "position": 3, "name": `${la.name} Schools`, "item": `https://catchment.school/council/${la.slug}` },
  ]
};
---
<Base title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <nav class="text-sm text-gray-500 mb-6 flex gap-2 items-center">
    <a href="/" class="hover:underline">Home</a>
    <span>›</span>
    <a href="/council" class="hover:underline">All Councils</a>
    <span>›</span>
    <span class="text-gray-700">{la.name}</span>
  </nav>

  <h1 class="text-3xl font-bold mb-3">{la.name} School Catchment Areas</h1>

  <!-- Intro paragraph — unique per LA using real counts -->
  <p class="text-gray-600 mb-2 max-w-2xl">
    <strong>{la.name}</strong> has <strong>{laSchools.length} schools</strong> across {townCount} area{townCount !== 1 ? 's' : ''} —
    {primaries} primary school{primaries !== 1 ? 's' : ''} and {secondaries} secondary school{secondaries !== 1 ? 's' : ''}.
    Catchment area boundaries and admissions policies for all schools in {la.name} are reviewed annually.
  </p>
  <div class="flex gap-6 text-gray-500 mb-8 text-sm">
    <span>{laSchools.length} total</span>
    <span>{primaries} primary</span>
    <span>{secondaries} secondary</span>
    <span>{townCount} area{townCount !== 1 ? 's' : ''}</span>
  </div>

  <!-- Admissions CTA -->
  <div class="bg-indigo-50 border border-indigo-200 rounded-lg p-5 mb-8 flex flex-col sm:flex-row sm:items-center gap-4">
    <div class="flex-1">
      <h2 class="font-semibold mb-1">{la.name} Catchment Area Documents</h2>
      <p class="text-sm text-gray-600">
        Official admissions policies and catchment boundary maps for {la.name} schools are published annually.
      </p>
    </div>
    <a
      href={`https://www.google.com/search?q=${encodeURIComponent(la.name + ' school admissions catchment area policy ' + new Date().getFullYear())}`}
      target="_blank"
      rel="nofollow noopener"
      class="shrink-0 bg-indigo-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg hover:bg-indigo-800 transition-colors"
    >
      Find admissions documents →
    </a>
  </div>

  <!-- Schools by town — H2 includes location -->
  {towns.map(([townName, townSchools]) => (
    <section class="mb-10">
      <div class="flex items-baseline gap-3 mb-4">
        <h2 class="text-xl font-semibold">Schools in {townName}</h2>
        <span class="text-sm text-gray-400">{townSchools.length} school{townSchools.length !== 1 ? 's' : ''}</span>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {townSchools.slice(0, 12).map((s: any) => <SchoolCard {...s} />)}
      </div>
      {townSchools.length > 12 && (
        <p class="mt-3 text-sm text-gray-500">
          Showing 12 of {townSchools.length}.{' '}
          <a href={`/area/${townSchools[0].townSlug}`} class="text-indigo-700 hover:underline">
            View all schools in {townName} →
          </a>
        </p>
      )}
    </section>
  ))}
</Base>
