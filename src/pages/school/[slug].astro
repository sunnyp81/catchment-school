---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import { env } from 'cloudflare:workers';

const { slug } = Astro.params;

if (!env?.DB) {
  return new Response('Service unavailable', { status: 503 });
}

const s = await env.DB.prepare('SELECT * FROM schools WHERE slug = ?').bind(slug).first();

if (!s) {
  return Astro.redirect('/404');
}

const nearby = (await env.DB
  .prepare('SELECT slug, name, type, postcode FROM schools WHERE town = ? AND phase = ? AND urn != ? LIMIT 6')
  .bind(s.town, s.phase, s.urn)
  .all()
).results;

const address = [s.street, s.locality, s.town, s.postcode].filter(Boolean).join(', ');
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(s.name + ' ' + s.postcode)}`;
const councilAdmissionsUrl = `https://www.google.com/search?q=${encodeURIComponent(s.la + ' school admissions catchment area ' + new Date().getFullYear())}`;

const isOversubscribed = s.capacity && s.pupils && s.pupils >= s.capacity;
const fillRate = s.capacity && s.pupils ? Math.round((s.pupils / s.capacity) * 100) : null;

const introFacts = [
  s.ageRange ? `serving pupils aged ${s.ageRange}` : null,
  s.pupils ? `with ${s.pupils} pupils` : null,
  s.capacity ? `and a capacity of ${s.capacity} places` : null,
].filter(Boolean).join(', ');

const phaseLower = s.phase.toLowerCase();
const typeDesc = s.type.toLowerCase().replace('school', '').trim();

const title = `${s.name} Catchment Area — ${s.phase} School in ${s.town} | catchment.school`;
const description = `${s.name} is a ${phaseLower} school in ${s.town}, ${s.la}${introFacts ? ` ${introFacts}` : ''}. View catchment area guidance, admissions policy and nearby ${phaseLower} schools.`;

const schoolSchema = {
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  "name": s.name,
  "description": `${s.name} is a ${phaseLower} school in ${s.town}, ${s.la}, England.`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": [s.street, s.locality].filter(Boolean).join(', '),
    "addressLocality": s.town,
    "postalCode": s.postcode,
    "addressCountry": "GB"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": s.lat,
    "longitude": s.lng
  },
  ...(s.website ? { "url": s.website.startsWith('http') ? s.website : 'https://' + s.website } : {}),
  ...(s.pupils ? { "numberOfStudents": s.pupils } : {}),
  "sameAs": [
    `https://get-information-about-schools.service.gov.uk/Establishments/Establishment/Details/${s.urn}`,
    `https://reports.ofsted.gov.uk/provider/21/${s.urn}`
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://catchment.school/" },
    { "@type": "ListItem", "position": 2, "name": s.la, "item": `https://catchment.school/council/${s.laSlug}` },
    ...(s.town ? [{ "@type": "ListItem", "position": 3, "name": s.town, "item": `https://catchment.school/area/${s.townSlug}` }] : []),
    { "@type": "ListItem", "position": s.town ? 4 : 3, "name": `${s.name} Catchment Area`, "item": `https://catchment.school/school/${s.slug}` },
  ]
};
---
<Base title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schoolSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <!-- Breadcrumb -->
  <nav class="text-sm text-gray-500 mb-6 flex gap-2 items-center flex-wrap">
    <a href="/" class="hover:underline">Home</a>
    <span>›</span>
    <a href={`/council/${s.laSlug}`} class="hover:underline">{s.la}</a>
    <span>›</span>
    {s.town && <><a href={`/area/${s.townSlug}`} class="hover:underline">{s.town}</a><span>›</span></>}
    <span class="text-gray-700 truncate max-w-xs">{s.name}</span>
  </nav>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2">

      <h1 class="text-3xl font-bold mb-2">{s.name} Catchment Area</h1>

      <p class="text-gray-600 mb-6">
        {s.name} is a {typeDesc ? `${typeDesc} ` : ''}{phaseLower} school in {s.town}{s.la ? `, ${s.la}` : ''}
        {introFacts ? `, ${introFacts}` : ''}.
        {isOversubscribed
          ? ` The school is currently at or above capacity, making catchment area proximity important for admissions.`
          : s.capacity && fillRate && fillRate >= 90
            ? ` The school is operating close to capacity — catchment area boundaries apply when the school is oversubscribed.`
            : ` Find catchment area guidance, admissions policy details and nearby ${phaseLower} schools below.`
        }
      </p>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
        {s.ageRange && (
          <div class="bg-indigo-50 rounded-lg p-4 text-center">
            <p class="text-2xl font-bold text-indigo-700">{s.ageRange}</p>
            <p class="text-xs text-gray-500 mt-1">Age range</p>
          </div>
        )}
        {s.pupils && (
          <div class="bg-indigo-50 rounded-lg p-4 text-center">
            <p class="text-2xl font-bold text-indigo-700">{s.pupils.toLocaleString()}</p>
            <p class="text-xs text-gray-500 mt-1">Pupils</p>
          </div>
        )}
        {s.capacity && (
          <div class={`rounded-lg p-4 text-center ${isOversubscribed ? 'bg-amber-50' : 'bg-indigo-50'}`}>
            <p class={`text-2xl font-bold ${isOversubscribed ? 'text-amber-600' : 'text-indigo-700'}`}>{s.capacity.toLocaleString()}</p>
            <p class="text-xs text-gray-500 mt-1">Capacity</p>
          </div>
        )}
        {fillRate && (
          <div class={`rounded-lg p-4 text-center ${fillRate >= 100 ? 'bg-red-50' : fillRate >= 90 ? 'bg-amber-50' : 'bg-green-50'}`}>
            <p class={`text-2xl font-bold ${fillRate >= 100 ? 'text-red-600' : fillRate >= 90 ? 'text-amber-600' : 'text-green-700'}`}>{fillRate}%</p>
            <p class="text-xs text-gray-500 mt-1">Fill rate</p>
          </div>
        )}
      </div>

      <section id="catchment-area" class="mb-8">
        <h2 class="text-xl font-semibold mb-3">{s.name} Catchment Area Information</h2>
        <div class="bg-amber-50 border border-amber-200 rounded-lg p-5">
          <p class="text-sm text-gray-700 mb-3">
            The catchment area for <strong>{s.name}</strong> is set by <strong>{s.la}</strong> and reviewed annually.
            Catchment boundaries determine which children receive priority consideration when the school is oversubscribed.
          </p>
          {isOversubscribed && (
            <div class="bg-amber-100 border border-amber-300 rounded p-3 mb-3 text-sm text-amber-800">
              <strong>Currently oversubscribed:</strong> {s.pupils} pupils enrolled against a capacity of {s.capacity} places.
              Living within the catchment area is especially important for this school.
            </div>
          )}
          <p class="text-sm text-gray-700 mb-4">
            The official admissions policy — including the catchment boundary map — is published by {s.la} each year.
            Always verify your address with the council before submitting an application.
          </p>
          <a
            href={councilAdmissionsUrl}
            target="_blank"
            rel="nofollow noopener"
            class="inline-block bg-indigo-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg hover:bg-indigo-800 transition-colors"
          >
            Find {s.la} catchment area documents →
          </a>
        </div>
      </section>

      <section class="mb-8">
        <h2 class="text-xl font-semibold mb-4">{s.name} — School Information</h2>
        <dl class="divide-y border rounded-lg overflow-hidden">
          {([
            ['Full address', address],
            ['Local authority', s.la],
            ['School type', s.type],
            ['Phase of education', s.phase],
            ['Age range', s.ageRange ? `${s.ageRange} years` : null],
            ['Gender', s.gender !== 'Mixed' ? s.gender : null],
            ['Religious character', s.religion && s.religion !== 'Does not apply' && s.religion !== 'None' ? s.religion : null],
            ['Admissions policy', s.admissionsPolicy && s.admissionsPolicy !== 'Not applicable' ? s.admissionsPolicy : null],
            ['Free school meals', s.fsm ? `${s.fsm}% of pupils` : null],
            ['DfE URN', s.urn],
          ] as [string, string | null][]).filter(([, v]) => v).map(([label, value]) => (
            <div class="flex px-4 py-3 text-sm">
              <dt class="w-48 font-medium text-gray-500 shrink-0">{label}</dt>
              <dd class="text-gray-900">{value}</dd>
            </div>
          ))}
        </dl>
      </section>

      {nearby.length > 0 && (
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">Other {s.phase} Schools in {s.town}</h2>
          <p class="text-sm text-gray-600 mb-4">
            If {s.name} is oversubscribed, these {phaseLower} schools in {s.town} are the next closest alternatives.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {nearby.map((n: any) => (
              <a href={`/school/${n.slug}`} class="block border rounded-lg p-4 hover:border-indigo-400 transition-colors">
                <p class="font-medium text-indigo-700 text-sm hover:underline">{n.name} Catchment Area</p>
                <p class="text-xs text-gray-500 mt-1">{n.type} · {n.postcode}</p>
              </a>
            ))}
          </div>
        </section>
      )}

      <div class="border rounded-lg p-5 bg-gray-50 text-sm">
        <p class="font-medium mb-2">Need help understanding catchment areas?</p>
        <div class="flex flex-wrap gap-3">
          <a href="/guides/how-school-catchment-areas-work" class="text-indigo-700 hover:underline">How catchment areas work →</a>
          <a href="/guides/school-admissions-timeline" class="text-indigo-700 hover:underline">Admissions timeline →</a>
          {s.phase === 'Primary' && <a href="/guides/primary-school-catchment" class="text-indigo-700 hover:underline">Primary school guide →</a>}
          {s.phase === 'Secondary' && <a href="/guides/secondary-school-catchment" class="text-indigo-700 hover:underline">Secondary school guide →</a>}
        </div>
      </div>
    </div>

    <aside class="space-y-4">
      <div class="border rounded-lg p-5">
        <h3 class="font-semibold mb-3">Location</h3>
        <p class="text-sm text-gray-600 mb-3">{address}</p>
        <a href={mapsUrl} target="_blank" rel="nofollow noopener"
          class="block text-center border border-indigo-200 text-indigo-700 text-sm font-medium px-4 py-2 rounded-lg hover:bg-indigo-50 transition-colors">
          View on Google Maps →
        </a>
      </div>

      {s.website && (
        <div class="border rounded-lg p-5">
          <h3 class="font-semibold mb-2">School Website</h3>
          <a href={s.website.startsWith('http') ? s.website : 'https://' + s.website}
            target="_blank" rel="nofollow noopener"
            class="text-sm text-indigo-700 hover:underline break-all">
            {s.website}
          </a>
        </div>
      )}

      <div class="border rounded-lg p-5">
        <h3 class="font-semibold mb-3">Official Data</h3>
        <a href={`https://get-information-about-schools.service.gov.uk/Establishments/Establishment/Details/${s.urn}`}
          target="_blank" rel="nofollow noopener"
          class="block text-sm text-indigo-700 hover:underline mb-2">
          DfE Get Information About Schools →
        </a>
        <a href={`https://reports.ofsted.gov.uk/provider/21/${s.urn}`}
          target="_blank" rel="nofollow noopener"
          class="block text-sm text-indigo-700 hover:underline">
          Ofsted inspection reports →
        </a>
      </div>

      <div class="border rounded-lg p-5">
        <h3 class="font-semibold mb-3">Browse {s.town}</h3>
        {s.town && <a href={`/area/${s.townSlug}`} class="block text-sm text-indigo-700 hover:underline mb-2">All schools in {s.town} →</a>}
        <a href={`/council/${s.laSlug}`} class="block text-sm text-indigo-700 hover:underline">All schools in {s.la} →</a>
      </div>

      <div class="border rounded-lg p-5 bg-gray-50 text-center text-xs text-gray-400 min-h-[100px] flex items-center justify-center">
        Advertisement
      </div>
    </aside>
  </div>
</Base>
