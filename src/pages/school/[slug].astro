---
import Base from '../../layouts/Base.astro';
import schools from '../../data/schools.json';

export async function getStaticPaths() {
  return schools.map((s: any) => ({
    params: { slug: s.slug },
    props: { school: s },
  }));
}

const { school: s } = Astro.props;

const nearby = (schools as any[])
  .filter((n: any) => n.town === s.town && n.urn !== s.urn && n.phase === s.phase)
  .slice(0, 6);

const address = [s.street, s.locality, s.town, s.postcode].filter(Boolean).join(', ');
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(s.name + ' ' + s.postcode)}`;
const councilAdmissionsUrl = `https://www.google.com/search?q=${encodeURIComponent(s.la + ' school admissions catchment area ' + new Date().getFullYear())}`;

const isOversubscribed = s.capacity && s.pupils && s.pupils >= s.capacity;
const fillRate = s.capacity && s.pupils ? Math.round((s.pupils / s.capacity) * 100) : null;

const title = `${s.name} Catchment Area — ${s.phase} School in ${s.town} | catchment.school`;
const description = `${s.name} is a ${s.type.toLowerCase()} in ${s.town}, ${s.la}. ${s.capacity ? `Capacity ${s.capacity}` : ''}${s.pupils ? `, ${s.pupils} pupils` : ''}${s.ageRange ? `, ages ${s.ageRange}` : ''}. Find catchment area info and admissions guidance.`;

// JSON-LD schema
const schema = {
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  "name": s.name,
  "description": `${s.name} is a ${s.phase.toLowerCase()} school in ${s.town}, ${s.la}, England.`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": [s.street, s.locality].filter(Boolean).join(', '),
    "addressLocality": s.town,
    "postalCode": s.postcode,
    "addressCountry": "GB"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": s.lat,
    "longitude": s.lng
  },
  "url": s.website ? (s.website.startsWith('http') ? s.website : 'https://' + s.website) : undefined,
  "numberOfStudents": s.pupils ?? undefined,
  "foundingDate": undefined,
  "sameAs": [
    `https://get-information-about-schools.service.gov.uk/Establishments/Establishment/Details/${s.urn}`
  ]
};
---
<Base title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <!-- Breadcrumb -->
  <nav class="text-sm text-gray-500 mb-6 flex gap-2 items-center flex-wrap">
    <a href="/" class="hover:underline">Home</a>
    <span>›</span>
    <a href={`/council/${s.laSlug}`} class="hover:underline">{s.la}</a>
    <span>›</span>
    {s.town && <><a href={`/area/${s.townSlug}`} class="hover:underline">{s.town}</a><span>›</span></>}
    <span class="text-gray-700 truncate max-w-xs">{s.name}</span>
  </nav>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2">
      <h1 class="text-3xl font-bold mb-1">{s.name}</h1>
      <p class="text-gray-500 mb-6">{s.phase} school · {s.type}{s.la ? ` · ${s.la}` : ''}</p>

      <!-- Key stats -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
        {s.ageRange && (
          <div class="bg-indigo-50 rounded-lg p-4 text-center">
            <p class="text-2xl font-bold text-indigo-700">{s.ageRange}</p>
            <p class="text-xs text-gray-500 mt-1">Age range</p>
          </div>
        )}
        {s.pupils && (
          <div class="bg-indigo-50 rounded-lg p-4 text-center">
            <p class="text-2xl font-bold text-indigo-700">{s.pupils.toLocaleString()}</p>
            <p class="text-xs text-gray-500 mt-1">Pupils</p>
          </div>
        )}
        {s.capacity && (
          <div class={`rounded-lg p-4 text-center ${isOversubscribed ? 'bg-amber-50' : 'bg-indigo-50'}`}>
            <p class={`text-2xl font-bold ${isOversubscribed ? 'text-amber-600' : 'text-indigo-700'}`}>{s.capacity.toLocaleString()}</p>
            <p class="text-xs text-gray-500 mt-1">Capacity</p>
          </div>
        )}
        {fillRate && (
          <div class={`rounded-lg p-4 text-center ${fillRate >= 100 ? 'bg-red-50' : fillRate >= 90 ? 'bg-amber-50' : 'bg-green-50'}`}>
            <p class={`text-2xl font-bold ${fillRate >= 100 ? 'text-red-600' : fillRate >= 90 ? 'text-amber-600' : 'text-green-700'}`}>{fillRate}%</p>
            <p class="text-xs text-gray-500 mt-1">Fill rate</p>
          </div>
        )}
      </div>

      <!-- Catchment area section — semantic anchor -->
      <section id="catchment-area" class="mb-8">
        <h2 class="text-xl font-semibold mb-3">{s.name} Catchment Area</h2>
        <div class="bg-amber-50 border border-amber-200 rounded-lg p-5">
          <p class="text-sm text-gray-700 mb-3">
            The catchment area for <strong>{s.name}</strong> is set by <strong>{s.la}</strong> and reviewed annually.
            Catchment boundaries determine which children receive <em>priority consideration</em> when the school is oversubscribed.
          </p>
          {isOversubscribed && (
            <div class="bg-amber-100 border border-amber-300 rounded p-3 mb-3 text-sm text-amber-800">
              <strong>Note:</strong> This school is currently at or above capacity ({s.pupils} pupils / {s.capacity} places).
              Catchment area boundaries are particularly important for oversubscribed schools.
            </div>
          )}
          <p class="text-sm text-gray-700 mb-4">
            The official admissions policy — including the exact catchment boundary map — is published by {s.la} each year.
            Always verify your address directly with the council before submitting an application.
          </p>
          <a
            href={councilAdmissionsUrl}
            target="_blank"
            rel="nofollow noopener"
            class="inline-block bg-indigo-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg hover:bg-indigo-800 transition-colors"
          >
            Find {s.la} catchment area documents →
          </a>
        </div>
      </section>

      <!-- School details -->
      <section class="mb-8">
        <h2 class="text-xl font-semibold mb-4">School Information</h2>
        <dl class="divide-y border rounded-lg overflow-hidden">
          {([
            ['Full address', address],
            ['Local authority', s.la],
            ['School type', s.type],
            ['Phase of education', s.phase],
            ['Age range', s.ageRange ? `${s.ageRange} years` : null],
            ['Gender', s.gender !== 'Mixed' ? s.gender : null],
            ['Religious character', s.religion && s.religion !== 'Does not apply' && s.religion !== 'None' ? s.religion : null],
            ['Admissions policy', s.admissionsPolicy && s.admissionsPolicy !== 'Not applicable' ? s.admissionsPolicy : null],
            ['Free school meals', s.fsm ? `${s.fsm}% of pupils` : null],
            ['URN', s.urn],
          ] as [string, string | null][]).filter(([, v]) => v).map(([label, value]) => (
            <div class="flex px-4 py-3 text-sm">
              <dt class="w-48 font-medium text-gray-500 shrink-0">{label}</dt>
              <dd class="text-gray-900">{value}</dd>
            </div>
          ))}
        </dl>
      </section>

      <!-- How catchment areas work — semantic content for ranking -->
      <section class="mb-8 border-t pt-8">
        <h2 class="text-xl font-semibold mb-4">How Catchment Areas Work in {s.la}</h2>
        <div class="prose prose-sm max-w-none text-gray-700">
          <p>
            In England, school catchment areas are not fixed legal boundaries — they are the result of
            oversubscription criteria applied in descending order. Most schools in {s.la} prioritise:
          </p>
          <ol>
            <li><strong>Children in care</strong> (looked-after children and previously looked-after children)</li>
            <li><strong>Medical or social need</strong> — where attendance at this specific school is essential</li>
            <li><strong>Siblings</strong> — children with a brother or sister already at the school</li>
            <li><strong>Distance</strong> — straight-line distance from home address to school gate</li>
          </ol>
          <p>
            The term "catchment area" typically refers to the distance within which children were offered a place
            in the most recent admissions round. This distance varies each year based on the number of applicants.
          </p>
          <p>
            To check whether your address is likely to fall within the catchment for {s.name},
            compare your distance to the school with the last-distance-offered figure published by {s.la}
            in their annual admissions outcome data.
          </p>
        </div>
      </section>

      <!-- Nearby schools -->
      {nearby.length > 0 && (
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">Other {s.phase} Schools near {s.town}</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {nearby.map((n: any) => (
              <a href={`/school/${n.slug}`} class="block border rounded-lg p-4 hover:border-indigo-400 transition-colors">
                <p class="font-medium text-indigo-700 text-sm hover:underline">{n.name}</p>
                <p class="text-xs text-gray-500 mt-1">{n.type} · {n.postcode}</p>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>

    <!-- Sidebar -->
    <aside class="space-y-4">
      <div class="border rounded-lg p-5">
        <h3 class="font-semibold mb-3">Location</h3>
        <p class="text-sm text-gray-600 mb-3">{address}</p>
        <a href={mapsUrl} target="_blank" rel="nofollow noopener"
          class="block text-center border border-indigo-200 text-indigo-700 text-sm font-medium px-4 py-2 rounded-lg hover:bg-indigo-50 transition-colors">
          View on Google Maps →
        </a>
      </div>

      {s.website && (
        <div class="border rounded-lg p-5">
          <h3 class="font-semibold mb-2">School Website</h3>
          <a href={s.website.startsWith('http') ? s.website : 'https://' + s.website}
            target="_blank" rel="nofollow noopener"
            class="text-sm text-indigo-700 hover:underline break-all">
            {s.website}
          </a>
        </div>
      )}

      <div class="border rounded-lg p-5">
        <h3 class="font-semibold mb-3">Official Data</h3>
        <a href={`https://get-information-about-schools.service.gov.uk/Establishments/Establishment/Details/${s.urn}`}
          target="_blank" rel="nofollow noopener"
          class="block text-sm text-indigo-700 hover:underline mb-2">
          View on GIAS (DfE) →
        </a>
        <a href={`https://reports.ofsted.gov.uk/provider/21/${s.urn}`}
          target="_blank" rel="nofollow noopener"
          class="block text-sm text-indigo-700 hover:underline">
          View Ofsted reports →
        </a>
      </div>

      <div class="border rounded-lg p-5">
        <h3 class="font-semibold mb-3">Browse Area</h3>
        {s.town && <a href={`/area/${s.townSlug}`} class="block text-sm text-indigo-700 hover:underline mb-2">All schools in {s.town} →</a>}
        <a href={`/council/${s.laSlug}`} class="block text-sm text-indigo-700 hover:underline">All schools in {s.la} →</a>
      </div>

      <div class="border rounded-lg p-5 bg-gray-50 text-center text-xs text-gray-400 min-h-[100px] flex items-center justify-center">
        Advertisement
      </div>
    </aside>
  </div>
</Base>
