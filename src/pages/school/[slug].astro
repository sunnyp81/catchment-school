---
import Base from '../../layouts/Base.astro';
import schools from '../../data/schools.json';

const { slug } = Astro.params;
const s = (schools as any[]).find((s: any) => s.slug === slug);

if (!s) return Astro.redirect('/404');

// Build nearby schools (same town, same phase, not this school)
const nearby = (schools as any[])
  .filter((n: any) => n.town === s.town && n.urn !== s.urn && n.phase === s.phase)
  .slice(0, 6);

const address = [s.street, s.locality, s.town, s.postcode].filter(Boolean).join(', ');
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(s.name + ' ' + s.postcode)}`;
const councilAdmissionsUrl = `https://www.google.com/search?q=${encodeURIComponent(s.la + ' council school admissions catchment area')}`;

const title = `${s.name} — Catchment Area & School Info | catchment.school`;
const description = `${s.name} is a ${s.phase.toLowerCase()} school in ${s.town}${s.la ? ', ' + s.la : ''}. View capacity, admissions policy, and nearby schools.`;
---
<Base title={title} description={description}>
  <!-- Breadcrumb -->
  <nav class="text-sm text-gray-500 mb-6 flex gap-2 items-center flex-wrap">
    <a href="/" class="hover:underline">Home</a>
    <span>›</span>
    <a href={`/council/${s.laSlug}`} class="hover:underline">{s.la}</a>
    <span>›</span>
    {s.town && <><a href={`/area/${s.townSlug}`} class="hover:underline">{s.town}</a><span>›</span></>}
    <span class="text-gray-700">{s.name}</span>
  </nav>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Main -->
    <div class="lg:col-span-2">
      <h1 class="text-3xl font-bold mb-1">{s.name}</h1>
      <p class="text-gray-500 mb-6">{s.phase} school · {s.type}</p>

      <!-- Key stats -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
        {s.ageRange && (
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <p class="text-2xl font-bold text-indigo-700">{s.ageRange}</p>
            <p class="text-xs text-gray-500 mt-1">Age range</p>
          </div>
        )}
        {s.pupils && (
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <p class="text-2xl font-bold text-indigo-700">{s.pupils.toLocaleString()}</p>
            <p class="text-xs text-gray-500 mt-1">Pupils</p>
          </div>
        )}
        {s.capacity && (
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <p class="text-2xl font-bold text-indigo-700">{s.capacity.toLocaleString()}</p>
            <p class="text-xs text-gray-500 mt-1">Capacity</p>
          </div>
        )}
        {s.fsm && (
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <p class="text-2xl font-bold text-indigo-700">{s.fsm}%</p>
            <p class="text-xs text-gray-500 mt-1">Free school meals</p>
          </div>
        )}
      </div>

      <!-- School details -->
      <h2 class="text-xl font-semibold mb-4">School Details</h2>
      <dl class="divide-y border rounded-lg overflow-hidden mb-8">
        {[
          ['Address', address],
          ['Local Authority', s.la],
          ['School Type', s.type],
          ['Phase', s.phase],
          ['Gender', s.gender],
          ['Religion / Ethos', s.religion !== 'Does not apply' ? s.religion : null],
          ['Admissions Policy', s.admissionsPolicy !== 'Not applicable' ? s.admissionsPolicy : null],
        ].filter(([, v]) => v).map(([label, value]) => (
          <div class="flex px-4 py-3 text-sm">
            <dt class="w-48 font-medium text-gray-600 shrink-0">{label}</dt>
            <dd class="text-gray-900">{value}</dd>
          </div>
        ))}
      </dl>

      <!-- Catchment area -->
      <h2 class="text-xl font-semibold mb-3">Catchment Area Information</h2>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-5 mb-8">
        <p class="text-sm text-gray-700 mb-4">
          Catchment area boundaries are set by <strong>{s.la}</strong> and can change each year. The official admissions policy is the authoritative source for whether your address falls within the catchment.
        </p>
        <a
          href={councilAdmissionsUrl}
          target="_blank"
          rel="nofollow noopener"
          class="inline-block bg-indigo-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg hover:bg-indigo-800 transition-colors"
        >
          Find {s.la} catchment area docs →
        </a>
      </div>

      <!-- Nearby schools -->
      {nearby.length > 0 && (
        <h2 class="text-xl font-semibold mb-4">Other {s.phase} Schools in {s.town}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {nearby.map((n: any) => (
            <a href={`/school/${n.slug}`} class="block border rounded-lg p-4 hover:border-indigo-400 transition-colors">
              <p class="font-medium text-indigo-700 text-sm hover:underline">{n.name}</p>
              <p class="text-xs text-gray-500 mt-1">{n.type} · {n.postcode}</p>
            </a>
          ))}
        </div>
      )}
    </div>

    <!-- Sidebar -->
    <aside class="space-y-4">
      <!-- Map link -->
      <div class="border rounded-lg p-5">
        <h3 class="font-semibold mb-3">Location</h3>
        <p class="text-sm text-gray-600 mb-3">{address}</p>
        <a
          href={mapsUrl}
          target="_blank"
          rel="nofollow noopener"
          class="block text-center border border-indigo-200 text-indigo-700 text-sm font-medium px-4 py-2 rounded-lg hover:bg-indigo-50 transition-colors"
        >
          View on Google Maps →
        </a>
      </div>

      <!-- School website -->
      {s.website && (
        <div class="border rounded-lg p-5">
          <h3 class="font-semibold mb-3">School Website</h3>
          <a
            href={s.website.startsWith('http') ? s.website : 'https://' + s.website}
            target="_blank"
            rel="nofollow noopener"
            class="text-sm text-indigo-700 hover:underline break-all"
          >
            {s.website}
          </a>
        </div>
      )}

      <!-- Browse area -->
      <div class="border rounded-lg p-5">
        <h3 class="font-semibold mb-3">Browse Area</h3>
        <div class="space-y-2 text-sm">
          {s.town && <a href={`/area/${s.townSlug}`} class="block text-indigo-700 hover:underline">All schools in {s.town} →</a>}
          <a href={`/council/${s.laSlug}`} class="block text-indigo-700 hover:underline">All schools in {s.la} →</a>
        </div>
      </div>

      <!-- Ad slot -->
      <div class="border rounded-lg p-5 bg-gray-50 text-center text-xs text-gray-400">
        Advertisement
      </div>
    </aside>
  </div>
</Base>
