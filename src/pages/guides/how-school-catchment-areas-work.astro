        <ul class="space-y-2 text-sm">
          <li><a href="/guides/school-admissions-timeline" class="text-indigo-700 hover:underline">School admissions timeline</a></li>
          <li><a href="/guides/primary-school-catchment" class="text-indigo-700 hover:underline">Primary school catchment areas</a></li>
          <li><a href="/guides/secondary-school-catchment" class="text-indigo-700 hover:underline">Secondary school catchment areas</a></li>
        </ul>
      </div>
    </aside>
  </div>
</Base>
